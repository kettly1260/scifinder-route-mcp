SCIFINDER_ROUTE_IMAGE=ghcr.io/kettly1260/scifinder-route-mcp:latest
SCIFINDER_ROUTE_TRANSPORT=auto
SCIFINDER_ROUTE_HOST=0.0.0.0
SCIFINDER_ROUTE_PORT=8000
SCIFINDER_ROUTE_PUBLISHED_PORT=8000
SCIFINDER_ROUTE_ADMIN_ENABLED=true
SCIFINDER_ROUTE_ADMIN_HOST=0.0.0.0
SCIFINDER_ROUTE_ADMIN_PORT=8001
SCIFINDER_ROUTE_ADMIN_PUBLISHED_PORT=8001
SCIFINDER_ROUTE_MCP_PATH=/mcp
SCIFINDER_ROUTE_SSE_PATH=/sse
SCIFINDER_ROUTE_LOG_LEVEL=INFO
SCIFINDER_ROUTE_DATA_DIR=/data
SCIFINDER_ROUTE_INBOX_DIR=/inbox
SCIFINDER_ROUTE_UPLOAD_DIR=/data/uploads
SCIFINDER_ROUTE_EVIDENCE_DIR=/data/evidence
SCIFINDER_ROUTE_DATABASE=/data/scifinder_routes.sqlite3
SCIFINDER_ROUTE_CONFIG=/data/config.yaml
SCIFINDER_ROUTE_WEBUI_CONFIG=/data/webui-config.yaml
SCIFINDER_ROUTE_ASYNC_JOBS=true
SCIFINDER_ROUTE_MAX_WORKERS=1
SCIFINDER_ROUTE_BACKEND=sqlite
SCIFINDER_ROUTE_QUEUE_BACKEND=sqlite
SCIFINDER_ROUTE_REDIS_URL=
SCIFINDER_ROUTE_ALLOW_EXTERNAL_PATHS=false
SCIFINDER_ROUTE_SCAN_EXTENSIONS=.pdf,.rtf,.rdf,.html,.htm,.mhtml,.mht,.md,.markdown,.txt
SCIFINDER_ROUTE_UPLOAD_EXTENSIONS=.pdf,.rtf,.rdf,.html,.htm,.mhtml,.mht,.md,.markdown,.txt
SCIFINDER_ROUTE_UPLOAD_MAX_BYTES=52428800
SCIFINDER_ROUTE_REJECT_FILE_TYPE_MISMATCH=true
SCIFINDER_ROUTE_EXTRACT_VISUAL_EVIDENCE=true
SCIFINDER_ROUTE_RENDER_VISUAL_PAGES=true
SCIFINDER_ROUTE_VISUAL_PAGE_DPI=160
SCIFINDER_ROUTE_MAX_VISUAL_PAGES_PER_DOCUMENT=20
SCIFINDER_ROUTE_MAX_EMBEDDED_IMAGES_PER_DOCUMENT=100
SCIFINDER_ROUTE_UPLOAD_AV_SCAN_ENABLED=false
SCIFINDER_ROUTE_UPLOAD_AV_ENGINE=clamav
SCIFINDER_ROUTE_UPLOAD_AV_ENDPOINT=
SCIFINDER_ROUTE_UPLOAD_AV_FAIL_CLOSED=true
SCIFINDER_ROUTE_LLM_ENABLED=false
SCIFINDER_ROUTE_LLM_ENDPOINT=
SCIFINDER_ROUTE_LLM_MODEL=
SCIFINDER_ROUTE_LLM_SCHEMA_VERSION=reaction_step.v1
SCIFINDER_ROUTE_LLM_PROMPT_PROFILE=strict-reaction-json
SCIFINDER_ROUTE_LLM_COST_LIMIT_USD=0
SCIFINDER_ROUTE_EMBEDDING_ENDPOINT=
SCIFINDER_ROUTE_EMBEDDING_MODEL=
SCIFINDER_ROUTE_OCR_ENDPOINT=
SCIFINDER_ROUTE_OCR_MODEL=
SCIFINDER_ROUTE_DOCUMENT_PARSER_ENDPOINT=
SCIFINDER_ROUTE_DOCUMENT_PARSER_MODEL=
SCIFINDER_ROUTE_DOCUMENT_PARSER_FALLBACK=true
SCIFINDER_ROUTE_STRUCTURE_RECOGNITION_ENDPOINT=
SCIFINDER_ROUTE_STRUCTURE_RECOGNITION_MODEL=
SCIFINDER_ROUTE_POSTGRES_URL=
SCIFINDER_ROUTE_VERIFICATION_CONFIDENCE_THRESHOLD=0.65
SCIFINDER_ROUTE_EVIDENCE_RETENTION_DAYS=90
SCIFINDER_ROUTE_CACHE_RETENTION_DAYS=30
# Set this before exposing the service on a NAS network and pass the same token parameter to MCP tools.
SCIFINDER_ROUTE_TOKEN=change-me
# Optional multi-user tokens: username:token:role comma-separated; roles are viewer, operator, admin.
SCIFINDER_ROUTE_USERS=
